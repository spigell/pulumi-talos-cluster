{
    "name": "talos-cluster",
    "description": "Create and manage Talos kubernetes cluster",
    "keywords": [
        "pulumi",
        "talos",
        "category/infrastructure",
        "kind/component",
        "kubernetes"
    ],
    "license": "Apache-2.0",
    "repository": "https://github.com/spigell/pulumi-talos-cluster",
    "pluginDownloadURL": "github://api.github.com/spigell/pulumi-talos-cluster",
    "publisher": "spigell",
    "language": {
        "csharp": {
            "packageReferences": {
                "Pulumi": "3.*"
            }
        },
        "go": {
            "generateResourceContainerTypes": true,
            "importBasePath": "github.com/spigell/talos-cluster/sdk/go/change-me"
        },
        "nodejs": {
            "dependencies": {
                "@pulumi/command": "0.11.1",
                "@pulumi/pulumi": "^3.0.0"
            },
            "devDependencies": {
                "@types/node": "^20.0.0",
                "typescript": "^4.3.5"
            },
            "packageName": "@spigell/pulumi-talos-cluster"
        },
        "python": {
            "liftSingleValueMethodReturns": true,
            "pyproject": {
                "enabled": true
            },
            "requires": {
                "pulumi": "\u003e=3.0.0,\u003c4.0.0"
            },
            "usesIOClasses": true
        }
    },
    "config": {},
    "types": {
        "index:nodes": {
            "properties": {
                "nodes": {}
            },
            "type": "object"
        }
    },
    "provider": {},
    "resources": {
        "talos-clustertalos-cluster:index:Cluster": {
            "description": "Initialize a new talos cluster: creates secrets and configure ",
            "properties": {
                "usedata": {
                    "type": "object"
                }
            },
            "inputProperties": {
                "machines": {
                    "type": "object",
                    "$ref": "#types/index:nodes",
                    "description": "Configuration for machines"
                }
            },
            "isComponent": true
        }
    }
}